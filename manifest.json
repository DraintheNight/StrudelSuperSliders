{
  "manifest_version": 3,
  "name": "StrudelSuperSliders",
  "version": "1.0",
  "content_scripts": [
    {
      "matches": ["*://strudel.cc/*", "*://strudel.tidalcycles.org/*"],
      "js": [
        "errorHighlighter.js",
        "injected.js"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
    "data_collection_permissions": {
      "required": [
        "none"
      ]
    },
      "id": "strudelsupersliders@gmail.com",
      "strict_min_version": "140.0"
    }
  }
}
